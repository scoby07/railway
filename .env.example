# ============================================================
#  PixelUp AI — Environment Configuration
#  JANGAN commit file .env ke repository (tambahkan ke .gitignore)
# ============================================================

# ── SERVER ─────────────────────────────────────────────────
PORT=3001
NODE_ENV=production
APP_URL=https://pixelup.ai
FRONTEND_URL=https://pixelup.ai

# ── DATABASE ───────────────────────────────────────────────
DB_PATH=./database/pixelup.db

# ── JWT SECRETS ────────────────────────────────────────────
# Generate dengan: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=GANTI_DENGAN_64_BYTE_HEX_RANDOM_DISINI
JWT_REFRESH_SECRET=GANTI_DENGAN_64_BYTE_HEX_RANDOM_BERBEDA
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ── ENCRYPTION ─────────────────────────────────────────────
# Generate dengan: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=GANTI_DENGAN_32_BYTE_HEX_RANDOM

# ── SECURITY ───────────────────────────────────────────────
BCRYPT_ROUNDS=12
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=30
SESSION_SECRET=GANTI_DENGAN_STRING_RANDOM_PANJANG

# ── RATE LIMITING ──────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=5

# ── FILE UPLOAD ────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=200
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp,image/tiff
ALLOWED_VIDEO_TYPES=video/mp4,video/quicktime,video/x-msvideo

# ── CORS ───────────────────────────────────────────────────
CORS_ORIGIN=https://pixelup.ai

# ── LOGGING ────────────────────────────────────────────────
LOG_DIR=./logs
LOG_LEVEL=info

# ── ADMIN DEFAULT (Hanya untuk seed pertama kali) ──────────
# Setelah seed, HAPUS baris ini dari .env
SEED_ADMIN_EMAIL=admin@pixelup.ai
SEED_ADMIN_PASSWORD=GANTI_PASSWORD_ADMIN_SEBELUM_SEED
SEED_ADMIN_NAME=Administrator
