# PixelUp AI — Railway Environment Variables
# Set semua ini di Railway Dashboard → Variables

# Server
PORT=3001
NODE_ENV=production

# JWT Secrets — WAJIB generate sendiri!
# Cara generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=GANTI_DENGAN_HEX_64_BYTE_RANDOM
JWT_REFRESH_SECRET=GANTI_DENGAN_HEX_64_BYTE_RANDOM_BERBEDA
JWT_ACCESS_EXPIRES=15m

# Encryption
# Cara generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=GANTI_DENGAN_HEX_32_BYTE_RANDOM

# Database (Railway akan simpan di dalam container)
DB_PATH=/app/pixelup.db

# Security
BCRYPT_ROUNDS=12
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=30
RATE_LIMIT_MAX=150
AUTH_RATE_LIMIT_MAX=10

# CORS — setelah deploy frontend, set ke URL frontend Anda
# Contoh: CORS_ORIGIN=https://pixelup.vercel.app
CORS_ORIGIN=*

# Admin awal — ISI INI sebelum deploy pertama
# Hapus setelah berhasil login!
SEED_ADMIN_EMAIL=admin@email-anda.com
SEED_ADMIN_PASSWORD=PasswordKuatAnda123!@#
SEED_ADMIN_NAME=Administrator
